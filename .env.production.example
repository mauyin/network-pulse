# Domain
DOMAIN=pulse.yourdomain.com
CORS_ORIGIN=https://pulse.yourdomain.com

# Secrets (generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=
REDIS_PASSWORD=
API_KEY=

# RPC URLs (at least one required for poller)
ETH_RPC_URL=
ARB_RPC_URL=
OPT_RPC_URL=
POLYGON_RPC_URL=
BSC_RPC_URL=
BASE_RPC_URL=
MANTLE_RPC_URL=

# Fallback RPCs (optional — 2nd provider per chain for failover)
ETH_RPC_URL_FALLBACK=
ARB_RPC_URL_FALLBACK=
OPT_RPC_URL_FALLBACK=
BASE_RPC_URL_FALLBACK=

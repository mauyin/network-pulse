# Chains config (local dev — relative to poller working dir)
CHAINS_CONFIG=../chains.json

# RPC endpoints (required)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPT_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
MANTLE_RPC_URL=https://mantle-mainnet.g.alchemy.com/v2/YOUR_KEY

# Host ports (change these to avoid conflicts with other projects)
POSTGRES_PORT=5433
REDIS_PORT=6380
API_PORT=3002
DASHBOARD_PORT=5174

# Database (for local dev — connects from host to Docker)
DATABASE_URL=postgres://dvn:dvn_password@localhost:5433/dvn_health

# Redis (for local dev — connects from host to Docker)
REDIS_URL=redis://:dvn_redis_password@localhost:6380

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "packet-sent",
  "title": "PacketSent",
  "description": "Event emitted when a cross-chain message is sent via LayerZero EndpointV2",
  "type": "object",
  "required": [
    "event_type", "chain_id", "block_number", "tx_hash", "log_index",
    "block_timestamp", "src_eid", "dst_eid", "sender", "receiver", "nonce", "guid"
  ],
  "properties": {
    "event_type": { "const": "PacketSent" },
    "chain_id": { "type": "integer", "description": "Source chain ID" },
    "block_number": { "type": "integer" },
    "tx_hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "log_index": { "type": "integer" },
    "block_timestamp": { "type": "integer", "description": "Unix timestamp" },
    "src_eid": { "type": "integer", "description": "LayerZero source endpoint ID" },
    "dst_eid": { "type": "integer", "description": "LayerZero destination endpoint ID" },
    "sender": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "receiver": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "nonce": { "type": "integer" },
    "guid": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "ingestion_timestamp": { "type": "integer", "description": "Unix timestamp when poller saw this event" }
  },
  "additionalProperties": false
}
